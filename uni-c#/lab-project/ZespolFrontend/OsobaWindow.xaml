<Window x:Class="ZespolFrontend.OsobaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZespolFrontend"
        mc:Ignorable="d"
        Title="OsobaWindow" Height="450" Width="400">
    <Grid>
        <Label Content="PESEL" HorizontalAlignment="Left" Height="27" Margin="61,59,0,0" VerticalAlignment="Top" Width="100"/>
        <TextBox x:Name="TxtPESEL" HorizontalAlignment="Left" Height="27" Margin="161,59,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="154"/>
        <Label Content="Imie" HorizontalAlignment="Left" Height="27" Margin="61,91,0,0" VerticalAlignment="Top" Width="100"/>
        <TextBox x:Name="TxtImie" HorizontalAlignment="Left" Height="27" Margin="161,91,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="154"/>
        <Label Content="Nazwisko" HorizontalAlignment="Left" Height="27" Margin="61,123,0,0" VerticalAlignment="Top" Width="100"/>
        <TextBox x:Name="TxtNazwisko" HorizontalAlignment="Left" Height="27" Margin="161,123,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="154"/>
        <Label Content="Data Urodzenia" HorizontalAlignment="Left" Height="27" Margin="61,155,0,0" VerticalAlignment="Top" Width="100"/>
        <TextBox x:Name="TxtDataUrodzenia" HorizontalAlignment="Left" Height="27" Margin="161,155,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="154"/>
        <Label Content="Funkcja" HorizontalAlignment="Left" Height="27" Margin="61,187,0,0" VerticalAlignment="Top" Width="100"/>
        <TextBox x:Name="TxtFunkcja" HorizontalAlignment="Left" Height="27" Margin="161,187,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="154"/>
        <Label Content="Doświadczenie" HorizontalAlignment="Left" Height="27" Margin="61,219,0,0" VerticalAlignment="Top" Width="100"/>
        <TextBox x:Name="TxtDoswiadczenie" HorizontalAlignment="Left" Height="27" Margin="161,219,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="154"/>
        <Label Content="Plec" HorizontalAlignment="Left" Height="27" Margin="61,251,0,0" VerticalAlignment="Top" Width="100"/>
        <ComboBox x:Name="ComboBox" HorizontalAlignment="Left" Height="27" Margin="161,251,0,0" VerticalAlignment="Top" Width="154">
            <ComboBoxItem x:Name="K">Kobieta</ComboBoxItem>
            <ComboBoxItem x:Name="M">Mężczyzna</ComboBoxItem>
        </ComboBox>
        <Button x:Name="BtnZatwierdz" Content="Zatwierdz" HorizontalAlignment="Left" Height="29" Margin="61,294,0,0" VerticalAlignment="Top" Width="126" Click="BtnZatwierdz_Click"/>
        <Button x:Name="BtnAnuluj" Content="Anuluj" HorizontalAlignment="Left" Height="29" Margin="192,294,0,0" VerticalAlignment="Top" Width="123"/>

    </Grid>
</Window>
